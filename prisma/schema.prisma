generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TrafficLog {
  id           Int      @id @default(autoincrement())
  source       String   // e.g., 'direct', 'instagram', 'whatsapp', 'google'
  state        String?  // e.g., 'Maharashtra'
  cityCategory String?  // e.g., 'Tier 1', 'Tier 2', 'Tier 3', 'Other'
  createdAt    DateTime @default(now())
}

model Job {
  id             Int           @id @default(autoincrement())
  title          String
  description    String
  location       String
  type           String        // e.g., 'Full-time', 'Part-time', 'Internship'
  salary         String?
  isActive       Boolean       @default(true)
  requiresGithub Boolean       @default(false)
  createdAt      DateTime      @default(now())
  applications   Application[]
}

model Application {
  id          Int      @id @default(autoincrement())
  jobId       Int
  name        String
  email       String
  phone       String
  address     String
  resumeLink  String
  linkedinUrl String?
  githubUrl   String?
  createdAt   DateTime @default(now())

  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
